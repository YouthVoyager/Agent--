{
  "server": {
    "address": ":8080",
    "read_header_timeout": "5s",
    "shutdown_timeout": "10s"
  },
  "observability": {
    "metrics_namespace": "gateway",
    "tracing": {
      "enabled": true
    },
    "opentelemetry": {
      "enabled": true,
      "service_name": "telemetry-gateway",
      "service_version": "production",
      "environment": "production",
      "endpoint": "http://otel-collector:4318",
      "insecure": true,
      "headers": {},
      "export_timeout": "10s",
      "traces": {
        "enabled": true,
        "endpoint": ""
      },
      "logs": {
        "enabled": true,
        "endpoint": ""
      }
    },
    "stack": {
      "enabled": true,
      "services": [
        {
          "name": "Grafana",
          "kind": "dashboard",
          "public_url": "http://localhost:3000",
          "health_url": "http://grafana:3000/api/health"
        },
        {
          "name": "Prometheus",
          "kind": "metrics-scrape",
          "public_url": "http://localhost:9090",
          "health_url": "http://prometheus:9090/-/ready"
        },
        {
          "name": "Mimir",
          "kind": "metrics-store",
          "public_url": "http://localhost:9009",
          "health_url": "http://mimir:9009/ready"
        },
        {
          "name": "Tempo",
          "kind": "traces-store",
          "public_url": "http://localhost:3200",
          "health_url": "http://tempo:3200/ready"
        },
        {
          "name": "Loki",
          "kind": "logs-store",
          "public_url": "http://localhost:3100",
          "health_url": "http://loki:3100/ready"
        },
        {
          "name": "OpenTelemetry Collector",
          "kind": "collector",
          "public_url": "http://localhost:13133",
          "health_url": "http://otel-collector:13133"
        }
      ],
      "dashboards": [
        {
          "name": "Agent Gateway Overview",
          "url": "http://localhost:3000/d/agent-gateway-overview/agent-gateway-overview?orgId=1&refresh=10s",
          "embed_url": "http://localhost:3000/d/agent-gateway-overview/agent-gateway-overview?orgId=1&refresh=10s&kiosk"
        }
      ]
    }
  },
  "auth": {
    "api_key": {
      "enabled": false,
      "header": "Authorization",
      "keys": []
    }
  },
  "rate_limit": {
    "user": {
      "enabled": false,
      "identity_header": "X-User-ID",
      "requests_per_second": 1,
      "burst": 1
    },
    "concurrency": {
      "enabled": false,
      "max_in_flight": 100
    }
  },
  "token_usage": {
    "enabled": true,
    "identity_header": "X-User-ID",
    "window": "24h",
    "default_budget_tokens": 100000,
    "default_max_completion_tokens": 1024,
    "user_budgets": {}
  },
  "ai": {
    "request_timeout": "30s",
    "first_token_timeout": "30s",
    "circuit_breaker": {
      "enabled": true,
      "failure_threshold": 3,
      "open_timeout": "30s",
      "half_open_max_requests": 1
    },
    "fallbacks": {
      "mock-a": ["mock-b"],
      "gpt-4o-mini": ["gpt-4.1-mini"]
    },
    "backends": [
      {
        "name": "mock-a",
        "type": "mock",
        "models": ["mock-a", "gpt-4o-mini"]
      },
      {
        "name": "mock-b",
        "type": "mock",
        "models": ["mock-b", "gpt-4.1-mini"]
      }
    ]
  }
}
